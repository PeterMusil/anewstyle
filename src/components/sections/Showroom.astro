---
import Icon from "../icons/Icon.astro";
import { useTranslations, type Lang } from "../../i18n/utils";

interface Props {
  id: string;
  lang?: Lang;
}

const { id, lang = "cs" } = Astro.props;
const t = useTranslations(lang);
---

<section id={id} class="light">
  <div class="container">
    <h2 class="title text-center title--mg-s">{t("gallery.title")}</h2>
    <p class="desc text-center">
      <span>{t("gallery.descPart1")}</span>
      <strong>{t("gallery.descPart2")}</strong>
      <span>{t("gallery.descPart3")}</span>
      <strong>{t("gallery.descPart4")}</strong>
      <span>{t("gallery.descPart5")}</span>
    </p>
  </div>
  <div class="container segment-filter-wrap">
    <div
      class="segment-filter"
      role="group"
      aria-label={t("gallery.filterAriaLabel")}
    >
      <button
        type="button"
        class="segment-filter__btn"
        data-filter=""
        aria-pressed="true"
      >
        <span>{t("gallery.filterAll")}</span>
      </button>
      <button
        type="button"
        class="segment-filter__btn"
        data-filter="video"
        aria-pressed="false"
      >
        <Icon name="play" />
        <span>{t("gallery.filterVideos")}</span>
      </button>
      <button
        type="button"
        class="segment-filter__btn"
        data-filter="image"
        aria-pressed="false"
      >
        <span>{t("gallery.filterImages")}</span>
      </button>
      <button
        type="button"
        class="segment-filter__btn"
        data-filter="360"
        aria-pressed="false"
      >
        <Icon name="360" />
        <span>{t("gallery.filter360")}</span>
      </button>
    </div>
  </div>
  <div class="container gallery">
    <a
      href="/assets/ATAK_bazen_2.webm"
      aria-label={t("products.stoneAsLighting")}
      data-fancybox="gallery"
      data-media="video"
      class="gitem"
      rel="noopener"
    >
      <div class="gitem__photo">
        <img
          src="/assets/ATAK_bazen_2.avif"
          loading="lazy"
          width="768"
          height="446"
