</section>

<script>
  const initGalleryFilter = () => {
    const gallery = document.querySelector<HTMLElement>(".gallery");
    const filter = gallery
      ?.closest("section")
      ?.querySelector<HTMLElement>(".segment-filter");
    if (!filter || !gallery) return;

    const buttons = filter.querySelectorAll<HTMLButtonElement>(
      ".segment-filter__btn"
    );

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn.getAttribute("aria-pressed") === "true") return;
        buttons.forEach((b) => b.setAttribute("aria-pressed", "false"));
        btn.setAttribute("aria-pressed", "true");

        const filter = btn.dataset.filter ?? "";
        if (filter) {
          gallery.setAttribute("data-filter", filter);
        } else {
          gallery.removeAttribute("data-filter");
        }
      });
    });
  };

  initGalleryFilter();
  document.addEventListener("astro:page-load", initGalleryFilter);
</script>
